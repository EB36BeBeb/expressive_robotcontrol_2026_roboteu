<!--
  simple_arm.xml  -  3-DOF robot arm model for MuJoCo
  Structure: worldbody > base > link1 > link2 > link3 > end_effector
  Actuators: position servo (3 units)
-->
<mujoco model="simple_arm">

  <option timestep="0.005" gravity="0 0 -9.81" solver="Newton" iterations="50"/>

  <default>
    <joint damping="0.5" armature="0.01"/>
    <geom contype="1" conaffinity="1" condim="3"
          material="mat_default" friction="0.7 0.005 0.0001"/>
  </default>

  <asset>
    <!-- Material Definitions -->
    <material name="mat_base"    rgba="0.2 0.2 0.2 1"/>
    <material name="mat_link1"   rgba="0.2 0.4 0.8 1"/>
    <material name="mat_link2"   rgba="0.4 0.6 1.0 1"/>
    <material name="mat_link3"   rgba="0.0 0.8 0.8 1"/>
    <material name="mat_ee"      rgba="1.0 0.2 0.2 1"/>
    <material name="mat_default" rgba="0.7 0.7 0.7 1"/>
    <material name="mat_floor"   rgba="0.5 0.5 0.5 1" reflectance="0.2"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light diffuse=".9 .9 .9" pos="0 0 3" dir="0 0 -1" castshadow="false"/>
    <light diffuse=".4 .4 .4" pos="2 2 2" dir="-1 -1 -1"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.01"
          material="mat_floor" pos="0 0 0"/>

    <!-- Base (Fixed) -->
    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="cylinder" size="0.05 0.025"
            pos="0 0 0.025" material="mat_base"/>
      <inertial pos="0 0 0.025" mass="1.0"
                diaginertia="0.01 0.01 0.01"/>

      <!-- Link 1 - shoulder_pan joint (Z axis rot) -->
      <body name="link1" pos="0 0 0.05">
        <joint name="shoulder_pan" type="hinge" axis="0 0 1"
               range="-180 180" pos="0 0 0"/>
        <geom name="link1_geom" type="box" size="0.02 0.02 0.075"
              pos="0 0 0.075" material="mat_link1"/>
        <inertial pos="0 0 0.075" mass="0.5"
                  diaginertia="0.001 0.001 0.0005"/>

        <!-- Link 2 - shoulder_lift joint (Y axis rot) -->
        <body name="link2" pos="0 0 0.15">
          <joint name="shoulder_lift" type="hinge" axis="0 1 0"
                 range="-90 90" pos="0 0 0"/>
          <geom name="link2_geom" type="box" size="0.0175 0.0175 0.075"
                pos="0 0 0.075" material="mat_link2"/>
          <inertial pos="0 0 0.075" mass="0.3"
                    diaginertia="0.0008 0.0008 0.0003"/>

          <!-- Link 3 - elbow joint (Y axis rot) -->
          <body name="link3" pos="0 0 0.15">
            <joint name="elbow" type="hinge" axis="0 1 0"
                   range="-90 90" pos="0 0 0"/>
            <geom name="link3_geom" type="box" size="0.015 0.015 0.06"
                  pos="0 0 0.06" material="mat_link3"/>
            <inertial pos="0 0 0.06" mass="0.2"
                      diaginertia="0.0005 0.0005 0.0002"/>

            <!-- End Effector (Fixed) -->
            <body name="end_effector" pos="0 0 0.12">
              <geom name="ee_geom" type="sphere" size="0.02"
                    material="mat_ee"/>
              <!-- Site for End Effector coordinate visualization -->
              <site name="ee_site" pos="0 0 0" size="0.01"
                    rgba="1 1 0 1" type="sphere"/>
            </body>

          </body><!-- link3 -->
        </body><!-- link2 -->
      </body><!-- link1 -->
    </body><!-- base -->

  </worldbody>

  <!-- Actuators (Position Servo) -->
  <actuator>
    <position name="act_shoulder_pan"  joint="shoulder_pan"
              kp="50" kv="5" ctrllimited="true" ctrlrange="-3.14159 3.14159"/>
    <position name="act_shoulder_lift" joint="shoulder_lift"
              kp="50" kv="5" ctrllimited="true" ctrlrange="-1.5708 1.5708"/>
    <position name="act_elbow"         joint="elbow"
              kp="40" kv="4" ctrllimited="true" ctrlrange="-1.5708 1.5708"/>
  </actuator>

  <!-- Sensors (For Measuring Joint Angles / Velocity) -->
  <sensor>
    <jointpos name="sensor_shoulder_pan"  joint="shoulder_pan"/>
    <jointpos name="sensor_shoulder_lift" joint="shoulder_lift"/>
    <jointpos name="sensor_elbow"         joint="elbow"/>
    <jointvel name="sensor_vel_pan"       joint="shoulder_pan"/>
    <jointvel name="sensor_vel_lift"      joint="shoulder_lift"/>
    <jointvel name="sensor_vel_elbow"     joint="elbow"/>
  </sensor>

</mujoco>
