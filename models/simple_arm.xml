<!--
  simple_arm.xml  -  6-DOF robot arm model for MuJoCo (Linear Slide + 5-DOF Arm)
-->
<mujoco model="simple_arm">

  <option timestep="0.005" gravity="0 0 -9.81" solver="Newton" iterations="50"/>

  <default>
    <joint damping="0.5" armature="0.01"/>
    <geom contype="1" conaffinity="1" condim="3"
          material="mat_default" friction="0.7 0.005 0.0001"/>
  </default>

  <asset>
    <material name="mat_base"    rgba="0.2 0.2 0.2 1"/>
    <material name="mat_link1"   rgba="0.2 0.4 0.8 1"/>
    <material name="mat_link2"   rgba="0.4 0.6 1.0 1"/>
    <material name="mat_link3"   rgba="0.0 0.8 0.8 1"/>
    <material name="mat_ee"      rgba="1.0 0.2 0.2 1"/>
    <material name="mat_default" rgba="0.7 0.7 0.7 1"/>
    <material name="mat_floor"   rgba="0.5 0.5 0.5 1" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light diffuse=".9 .9 .9" pos="0 0 3" dir="0 0 -1" castshadow="false"/>
    <light diffuse=".4 .4 .4" pos="2 2 2" dir="-1 -1 -1"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.01" material="mat_floor" pos="0 0 0"/>

    <!-- Target Marker -->
    <body name="target" pos="0.2 0.2 0.2" mocap="true">
      <geom name="target_geom" type="sphere" size="0.015" rgba="1 0 0 0.5" contype="0" conaffinity="0"/>
    </body>
<!-- Obstacle Marker (Visualization only, hidden by default) -->
<body name="obstacle" pos="0 0 -1" mocap="true">
  <geom name="obstacle_geom" type="sphere" size="0.04"
        rgba="0 0.2 1 0.8" contype="0" conaffinity="0"/>
</body>

    <!-- Rail -->
    <geom name="rail_geom" type="box" size="0.6 0.05 0.01" pos="0 0 0.01" material="mat_base"/>

    <!-- Linear Slider -->
    <body name="slider" pos="0 0 0.02">
      <joint name="base_rail" type="slide" axis="1 0 0" range="-0.5 0.5"/>
      <geom name="slider_geom" type="cylinder" size="0.06 0.02" pos="0 0 0.01" material="mat_default"/>
      
      <!-- Arm Base attached to slider -->
      <body name="base" pos="0 0 0.02">
        <geom name="base_geom" type="cylinder" size="0.05 0.025" pos="0 0 0.025" material="mat_base"/>

        <!-- Link 1 -->
        <body name="link1" pos="0 0 0.05">
          <joint name="shoulder_pan" type="hinge" axis="0 0 1" range="-180 180" pos="0 0 0"/>
          <geom name="link1_geom" type="box" size="0.02 0.02 0.075" pos="0 0 0.075" material="mat_link1"/>

          <!-- Link 2 -->
          <body name="link2" pos="0 0 0.15">
            <joint name="shoulder_lift" type="hinge" axis="0 1 0" range="-90 90" pos="0 0 0"/>
            <geom name="link2_geom" type="box" size="0.0175 0.0175 0.075" pos="0 0 0.075" material="mat_link2"/>

            <!-- Link 3 -->
            <body name="link3" pos="0 0 0.15">
              <joint name="elbow" type="hinge" axis="0 1 0" range="-90 90" pos="0 0 0"/>
              <geom name="link3_geom" type="box" size="0.015 0.015 0.05" pos="0 0 0.05" material="mat_link3"/>

              <!-- Link 4 -->
              <body name="link4" pos="0 0 0.10">
                <joint name="wrist_pitch" type="hinge" axis="0 1 0" range="-90 90" pos="0 0 0"/>
                <geom name="link4_geom" type="box" size="0.0125 0.0125 0.025" pos="0 0 0.025" material="mat_default"/>

                <!-- EE -->
                <body name="end_effector" pos="0 0 0.05">
                  <joint name="wrist_roll" type="hinge" axis="0 0 1" range="-180 180" pos="0 0 0"/>
                  <geom name="ee_geom" type="sphere" size="0.02" material="mat_ee"/>
                  <site name="ee_site" pos="0 0 0" size="0.01" rgba="1 1 0 1" type="sphere"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="act_base_rail"     joint="base_rail"     kp="200" kv="20" ctrlrange="-0.5 0.5" ctrllimited="true"/>
    <position name="act_shoulder_pan"  joint="shoulder_pan"  kp="50"  kv="5"  ctrlrange="-3.14 3.14" ctrllimited="true"/>
    <position name="act_shoulder_lift" joint="shoulder_lift" kp="50"  kv="5"  ctrlrange="-1.57 1.57" ctrllimited="true"/>
    <position name="act_elbow"         joint="elbow"         kp="40"  kv="4"  ctrlrange="-1.57 1.57" ctrllimited="true"/>
    <position name="act_wrist_pitch"   joint="wrist_pitch"   kp="30"  kv="3"  ctrlrange="-1.57 1.57" ctrllimited="true"/>
    <position name="act_wrist_roll"    joint="wrist_roll"    kp="20"  kv="2"  ctrlrange="-3.14 3.14" ctrllimited="true"/>
  </actuator>

  <sensor>
    <jointpos name="sensor_base_rail"     joint="base_rail"/>
    <jointpos name="sensor_shoulder_pan"  joint="shoulder_pan"/>
    <jointpos name="sensor_shoulder_lift" joint="shoulder_lift"/>
    <jointpos name="sensor_elbow"         joint="elbow"/>
    <jointpos name="sensor_wrist_pitch"   joint="wrist_pitch"/>
    <jointpos name="sensor_wrist_roll"    joint="wrist_roll"/>
  </sensor>

</mujoco>
